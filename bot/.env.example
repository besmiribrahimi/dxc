DISCORD_BOT_TOKEN=your_discord_bot_token
# Legacy fallback supported: DISCORD_TOKEN
DISCORD_CHANNEL_ID=your_target_channel_id
# Legacy fallback supported: CHANNEL_ID

# Optional for instant slash command updates in one server.
# If omitted, commands register globally (can take up to 1 hour to appear).
DISCORD_GUILD_ID=your_guild_id

# Required for /leaderboard command (use your live web API endpoint)
# Example: https://your-domain.com/api/leaderboard-config
LEADERBOARD_API_URL=
WEBSITE_HOME_URL=
WEBSITE_API_TOKEN=
LFG_QUEUE_API_URL=https://your-domain.com/api/lfg-queue.js
LEADERBOARD_CHANNEL_ID=
LEADERBOARD_AUTO_POST_ENABLED=false
LEADERBOARD_AUTO_POST_INTERVAL_HOURS=6

# Ticket defaults (can be changed per guild with /setup)
TICKET_ENABLED=true
TICKET_CATEGORY_ID=
TICKET_LOG_CHANNEL_ID=
TICKET_PING_ROLE_IDS=
TICKET_REVIEWER_ROLE_IDS=
TICKET_ALLOWED_ROLE_IDS=

# Branding and palette defaults
BRANDING_FOOTER=Ascend Entrenched
EMBED_INFO_COLOR=#C8A2C8
EMBED_WINNER_COLOR=#FFD700
EMBED_ACTIVE_COLOR=#C8A2C8
EMBED_ELIMINATED_COLOR=#9B59B6
EMBED_HIGHLIGHT_COLOR=#FFECB3

# Optional legacy application variables (still supported as fallbacks)
APPLICATIONS_CHANNEL_ID=
APPLICATIONS_REVIEWER_ROLE_ID=
APPLICATIONS_ACCEPTED_ROLE_ID=
APPLICATION_COOLDOWN_MS=120000

PORT=3001

# Optional but recommended. If set, POST requests must include header: x-webhook-secret
WEBHOOK_SHARED_SECRET=your_shared_secret

# Queue controls to avoid burst spam in Discord
QUEUE_INTERVAL_MS=1200
MAX_QUEUE_SIZE=200
